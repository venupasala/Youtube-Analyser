# ═══════════════════════════════════════════════════════════════
#  YouTube Account Analyzer — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── YouTube Data API v3 Key (REQUIRED) ────────────────────────
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your Google Cloud project
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Default Region for Trending Videos ────────────────────────
# ISO 3166-1 alpha-2 country code (US, IN, GB, CA, DE, FR, JP, BR, AU, KR)
DEFAULT_REGION=US

# ── Elasticsearch Settings ────────────────────────────────────
# JVM heap size (min/max) — recommended: 512m for dev, 1g+ for production
ES_JAVA_OPTS=-Xms512m -Xmx512m
